generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String            @id @default(cuid())
  name          String?
  email         String?           @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  profile       UserProfile?
  integrations  UserIntegration[]
  scheduledOrders ScheduledOrder[]
}

model UserProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  age              Int?
  height           Float? // in cm
  weight           Float? // in kg
  fitnessGoal      String? // weight_loss, muscle_gain, endurance, general_fitness
  activityType     String? // gym, cycling, running, marathon, general
  goalDescription  String?
  medicalCondition String? // User's medical conditions or health concerns
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserIntegration {
  id              String   @id @default(cuid())
  userId          String
  platform        String   // sillobite, figgy, komato
  platformUserId  String
  accessToken     String
  connectedAt     DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ScheduledOrder {
  id              String   @id @default(cuid())
  userId          String
  day             Int
  dayName         String
  mealType        String   // breakfast, lunch, dinner
  scheduledTime   String   // HH:MM format
  requirements    Json     // Meal requirements from diet plan
  status          String   @default("pending") // pending, scheduled, ordered, failed, skipped
  orderId         String?
  orderNumber     String?
  matchedItems    Json?
  error           String?
  executedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([scheduledTime, status])
}
